// SkyTracker — Prisma schema
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Auth.js v5 — Prisma adapter tables
// https://authjs.dev/getting-started/adapters/prisma
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// SkyTracker domain
// One global board (v1). Multiple boards = future work.
// Columns = developer lanes. Cards = tasks stacked by priority.
// ─────────────────────────────────────────────────────────────

enum TaskType {
  FEATURE
  WORK_ITEM
  BUG
  MAINTENANCE
  OTHER
}

enum EstimateType {
  HARD_DATE
  WEEKS
  SCOPES
  NONE
}

model Board {
  id        String   @id @default(cuid())
  name      String   @default("SkyTracker")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  columns   Column[]
  cards     Card[]
  auditLogs AuditLog[]
}

model Column {
  id          String   @id @default(cuid())
  boardId     String
  title       String
  description String?
  position    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId, position])
}

model Card {
  id             String       @id @default(cuid())
  boardId        String
  columnId       String
  title          String
  description    String?
  taskType       TaskType     @default(OTHER)
  estimate       String?      // freeform display label: "1 uke", "21. mai", "Scopes"
  estimateType   EstimateType @default(NONE)
  estimateDate   DateTime?    // populated when estimateType = HARD_DATE
  estimateWeeks  Int?         // populated when estimateType = WEEKS
  codeReview     Boolean      @default(false)
  isGap          Boolean      @default(false)
  gapSize        Int          @default(1)    // visual height in "slots" (1 slot ≈ 1 normal card)
  position       Int
  tags           Json         @default("[]") // [{ name: "Backend", applicable: true }, ...]
  adoWorkItemId  Int?         // Azure DevOps work item id when linked
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  board          Board        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column         Column       @relation(fields: [columnId], references: [id], onDelete: Cascade)
  blockedBy      Dependency[] @relation("BlockedCard")
  blocking       Dependency[] @relation("BlockerCard")

  @@index([columnId, position])
  @@index([boardId])
}

// ─────────────────────────────────────────────────────────────
// Cross-lane dependencies
// blockerCard must finish before blockedCard can start.
// ─────────────────────────────────────────────────────────────

model Dependency {
  id            String   @id @default(cuid())
  blockerCardId String
  blockedCardId String
  createdAt     DateTime @default(now())

  blockerCard Card @relation("BlockerCard", fields: [blockerCardId], references: [id], onDelete: Cascade)
  blockedCard Card @relation("BlockedCard", fields: [blockedCardId], references: [id], onDelete: Cascade)

  @@unique([blockerCardId, blockedCardId])
  @@index([blockedCardId])
}

// ─────────────────────────────────────────────────────────────
// Audit log — records every mutation for accountability
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  boardId    String
  userId     String?
  userName   String?
  action     String   // e.g. CARD_CREATED, CARD_MOVED, COLUMN_DELETED
  targetType String   // e.g. Card, Column
  targetId   String
  details    Json?    // before/after or relevant context
  createdAt  DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
  @@index([targetType, targetId])
}
