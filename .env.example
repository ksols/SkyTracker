# SkyTracker environment — copy to .env and fill in. Never commit .env.

# ── Database ────────────────────────────────────────────────
# Postgres connection string (local, Vercel/Prisma Postgres, Neon, …).
DATABASE_URL=""

# ── Auth.js v5 (Microsoft Entra ID) ─────────────────────────
AUTH_SECRET=""                              # npx auth secret
AUTH_MICROSOFT_ENTRA_ID_ID=""               # Entra app registration client id
AUTH_MICROSOFT_ENTRA_ID_SECRET=""           # Entra app registration client secret
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""           # https://login.microsoftonline.com/<tenant-id>/v2.0

# Entra group id whose members get write access (others are read-only).
SKYTRACKER_WRITERS_GROUP_ID=""

# ── Azure DevOps integration ────────────────────────────────
# PAT with Work Items (Read & Write). Used server-side to create work items
# from SkyTracker cards (the create-in-ADO feature).
SKYTRACKER_ADO_PAT=""

# PAT with iteration/team management scope. Used ONLY by the
# scripts/provision-sprints.ts admin tool to create future sprints. Not used
# by the running app.
ADO_PAT=""
